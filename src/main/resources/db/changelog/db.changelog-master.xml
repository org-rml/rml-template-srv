databaseChangeLog:
  # TODO: Adicionar changesets para criar as tabelas do serviço
  # Exemplo de estrutura:
  # - include:
  #     file: db/changelog/changes/001-create-sample-table.xml

  - changeSet:
      id: 001-create-samples-table
      author: rml
      changes:
        - createTable:
            tableName: samples
            columns:
              - column:
                  name: id
                  type: BIGINT
                  autoIncrement: true
                  constraints:
                    primaryKey: true
                    nullable: false
              - column:
                  name: name
                  type: VARCHAR(255)
                  constraints:
                    nullable: false
              - column:
                  name: created_at
                  type: TIMESTAMP
                  constraints:
                    nullable: false
              - column:
                  name: updated_at
                  type: TIMESTAMP
                  constraints:
                    nullable: false
